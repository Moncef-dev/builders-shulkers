{
	"schemaVersion": 1,
	"id": "builders-shulkers",
	"version": "${version}",
	"name": "Builder's Shulkers",
	"description": "Open and rearrange shulker box contents directly from your inventory, in a chest-style screen with a lid animation.",
	"authors": [
		"Moncef-dev"
	],
	"contact": {
		"homepage": "https://github.com/Moncef-dev/builders-shulkers",
		"sources": "https://github.com/Moncef-dev/builders-shulkers"
	},
	"license": "MIT",
	"icon": "assets/builders-shulkers/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"io.github.moncefdev.shulkerinventory.ShulkerInventory"
		],
		"client": [
			"io.github.moncefdev.shulkerinventory.client.ShulkerInventoryClient"
		]
	},
	"mixins": [
		"builders-shulkers.mixins.json",
		{
			"config": "builders-shulkers.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.2",
		"minecraft": "${minecraft_dep}",
		"java": ">=25",
		"fabric-api": "*"
	},
	"suggests": {
		"litematica": "*"
	}
}
